<odoo>
    <data noupdate="1">
        <record id="seq_vet_appointment" model="ir.sequence">
            <field name="name">Lịch hẹn khám</field>
            <field name="code">vet.appointment</field>
            <field name="prefix">APT/</field>
            <field name="padding">4</field>
        </record>
    </data>

    <record id="seq_vet_invoice" model="ir.sequence">
        <field name="name">Mã hóa đơn thú y</field>
        <field name="code">vet.invoice</field>
        <field name="prefix">VETINV/</field>
        <field name="padding">4</field>
    </record>

    <record id="seq_vet_medical_record" model="ir.sequence">
      <field name="name">Mã Hồ Sơ Khám</field>
      <field name="code">vet.medical.record</field>
      <field name="prefix">HSK/</field>
      <field name="padding">4</field>
      <field name="number_next">1</field>
    </record>
</odoo>

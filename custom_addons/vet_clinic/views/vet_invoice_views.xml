<odoo>
    <record id="view_vet_invoice_form" model="ir.ui.view">
        <field name="name">vet.invoice.form</field>
        <field name="model">vet.invoice</field>
        <field name="arch" type="xml">
            <form string="Hóa đơn thú y">
                <header>
                    <button name="open_invoice" string="Xem hóa đơn kế toán" type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="not_paid,paid,in_payment"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="medical_record_id"/>
                        <field name="invoice_id"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="amount_total" readonly="1"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vet_invoice_tree" model="ir.ui.view">
        <field name="name">vet.invoice.tree</field>
        <field name="model">vet.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="medical_record_id"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_vet_invoice" model="ir.actions.act_window">
        <field name="name">Hóa đơn thú y</field>
        <field name="res_model">vet.invoice</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vet_invoice"
              name="Hóa đơn thú y"
              parent="vet_clinic_main_menu"
              action="action_vet_invoice"
              sequence="40"/>
</odoo>

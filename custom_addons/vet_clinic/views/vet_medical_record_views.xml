<odoo>
    <record id="view_vet_medical_record_form" model="ir.ui.view">
        <field name="name">vet.medical.record.form</field>
        <field name="model">vet.medical.record</field>
        <field name="arch" type="xml">
            <form string="Hồ sơ khám bệnh">
                <header>
                    <button name="action_confirm" type="object" string="Xác nhận"/>
                    <button name="action_done" type="object" string="Hoàn thành"/>
                    <button name="action_create_invoice" type="object" string="Tạo hóa đơn"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,invoiced"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="patient_id"/>
                        <field name="appointment_id"/>
                        <field name="doctor_id"/>
                        <field name="date"/>
                        <field name="service_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="symptom"/>
                        <field name="diagnosis"/>
                        <field name="treatment"/>
                        <field name="invoice_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vet_medical_record" model="ir.actions.act_window">
        <field name="name">Hồ sơ khám</field>
        <field name="res_model">vet.medical.record</field>
        <field name="view_mode">list,form</field>
        <field name="type">ir.actions.act_window</field>
    </record>

    <menuitem id="menu_vet_medical_record" name="Hồ sơ khám" parent="vet_clinic_main_menu" action="action_vet_medical_record"/>
</odoo>

<odoo>
    <record id="view_vet_appointment_form" model="ir.ui.view">
        <field name="name">vet.appointment.form</field>
        <field name="model">vet.appointment</field>
        <field name="arch" type="xml">
            <form string="Lịch hẹn khám bệnh">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="patient_id"/>
                        <field name="owner_id" readonly="1"/>
                        <field name="appointment_date"/>
                        <field name="doctor_id"/>
                        <field name="state"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vet_appointment_tree" model="ir.ui.view">
        <field name="name">vet.appointment.tree</field>
        <field name="model">vet.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="appointment_date"/>
                <field name="doctor_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_vet_appointment_kanban" model="ir.ui.view">
        <field name="name">vet.appointment.kanban</field>
        <field name="model">vet.appointment</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong><br/>
                            <field name="patient_id"/><br/>
                            <field name="appointment_date"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vet_appointment_calendar" model="ir.ui.view">
        <field name="name">vet.appointment.calendar</field>
        <field name="model">vet.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Lịch hẹn" date_start="appointment_date" color="doctor_id" />
        </field>
    </record>

    <record id="action_vet_appointment" model="ir.actions.act_window">
        <field name="name">Lịch hẹn</field>
        <field name="res_model">vet.appointment</field>
        <field name="view_mode">list,form,kanban,calendar</field>
        <field name="type">ir.actions.act_window</field>
    </record>

    <menuitem id="menu_vet_appointment" name="Lịch hẹn" parent="vet_clinic_main_menu" action="action_vet_appointment" sequence="2"/>
</odoo>

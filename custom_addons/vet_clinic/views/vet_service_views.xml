<odoo>
    <record id="view_vet_service_form" model="ir.ui.view">
        <field name="name">vet.service.form</field>
        <field name="model">vet.service</field>
        <field name="arch" type="xml">
            <form string="Dịch vụ y tế">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="price"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

     <record id="view_vet_service_tree" model="ir.ui.view">
        <field name="name">vet.service.tree</field>
        <field name="model">vet.service</field>
        <field name="arch" type="xml">
            <list string="Dịch vụ y tế">
                <field name="name"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <record id="action_vet_service" model="ir.actions.act_window">
        <field name="name">Dịch vụ y tế</field>
        <field name="res_model">vet.service</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vet_service"
              name="Dịch vụ y tế"
              parent="vet_clinic_main_menu"
              action="action_vet_service"
              sequence="50"/>
</odoo>